MYSQL_ROOT_PASSWORD=change-me
AIMALL_DB_USERNAME=aimall_app
AIMALL_DB_PASSWORD=replace-with-a-database-password
AIMALL_DB_APP_PASSWORD=replace-with-a-database-password
AIMALL_BACKUP_DB_USERNAME=aimall_backup
AIMALL_BACKUP_DB_PASSWORD=replace-with-a-distinct-backup-password
AIMALL_BACKUP_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
AIMALL_BACKUP_OFFSITE_URI=
AIMALL_BACKUP_FULL_SCHEDULE=0 2 * * *
AIMALL_BINLOG_ARCHIVE_INTERVAL_SECONDS=300
AIMALL_BACKUP_RETENTION_DAYS=30
AIMALL_INTERNAL_API_SECRET=replace-with-a-long-random-secret
AIMALL_JAVA_TO_AI_KEY_ID=java-to-ai-v1
AIMALL_JAVA_TO_AI_SECRET=replace-with-a-distinct-long-random-secret
AIMALL_AI_TO_JAVA_KEY_ID=ai-to-java-v1
AIMALL_AI_TO_JAVA_SECRET=replace-with-another-distinct-long-random-secret
AIMALL_AI_TO_JAVA_PREVIOUS_KEY_ID=
AIMALL_AI_TO_JAVA_PREVIOUS_SECRET=
AIMALL_JAVA_TO_AI_PREVIOUS_KEY_ID=
AIMALL_JAVA_TO_AI_PREVIOUS_SECRET=
AIMALL_ADMIN_BOOTSTRAP_USERNAME=admin
AIMALL_ADMIN_BOOTSTRAP_PASSWORD=replace-with-at-least-12-characters
AIMALL_ADMIN_RESET_DEFAULT_PASSWORD=false
AIMALL_ENVIRONMENT=local
AIMALL_TENANT_MODE=SINGLE_TENANT
AIMALL_DEFAULT_TENANT_ID=default
AIMALL_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
AIMALL_UPLOAD_ANTIVIRUS_ENABLED=false
AIMALL_UPLOAD_ANTIVIRUS_REQUIRED=false
AIMALL_UPLOAD_ANTIVIRUS_HOST=127.0.0.1
AIMALL_UPLOAD_ANTIVIRUS_PORT=3310
SSE_MAX_GLOBAL_CONNECTIONS=200
SSE_MAX_CONNECTIONS_PER_CLIENT=4
SSE_MAX_DURATION_SECONDS=180
REDIS_MAX_CONNECTIONS=100
AIMALL_DB_POOL_MAX_SIZE=50
AIMALL_DB_POOL_MIN_IDLE=10
AIMALL_API_DOCS_ENABLED=false
AIMALL_EMAIL_ENABLED=true
AIMALL_EMAIL_FROM=AIMall <no-reply@aimall.local>
AIMALL_EMAIL_CODE_PEPPER=replace-with-a-long-random-email-code-pepper
AIMALL_EMAIL_CODE_TTL_MINUTES=10
AIMALL_EMAIL_SEND_COOLDOWN_SECONDS=60
AIMALL_EMAIL_CODE_MAX_ATTEMPTS=5
AIMALL_SMTP_HOST=127.0.0.1
AIMALL_SMTP_PORT=1025
AIMALL_SMTP_USERNAME=
AIMALL_SMTP_PASSWORD=
AIMALL_SMTP_AUTH=false
AIMALL_SMTP_STARTTLS=false
AIMALL_PAYMENT_SIMULATION_ENABLED=false
AIMALL_PAYMENT_PROVIDER=sandbox
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_SELLER_ID=
ALIPAY_PRIVATE_KEY_FILE=C:/secure/aimall/alipay-sandbox-app-private-key.pem
ALIPAY_PUBLIC_KEY_FILE=C:/secure/aimall/alipay-sandbox-alipay-public-key.pem
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_BASE_URL=
ALIPAY_RETURN_URL=
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_CHARSET=UTF-8
ALIPAY_FORMAT=json

AGNES_API_KEY=your-agnes-key
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash
AI_RUNTIME_MODE=LLM
AI_RUNTIME_MODE_PREVIOUS=LLM
AI_RUNTIME_MODE_ROLLOUT_PERCENT=100
AI_RUNTIME_MODE_CHANGE_ID=local-initial
AIMALL_INSTANCE_KEY=local-ai-1
RUNTIME_MODE_AUDIT_LOG=logs/runtime-mode-audit.jsonl
RAG_ENABLED=true
LLM_TIMEOUT=180

# Phase 19: task-aware model routing. Empty values fall back to AGNES_MODEL.
MODEL_ROUTING_ENABLED=true
AGNES_FAST_MODEL=agnes-2.0-flash
AGNES_PRIMARY_MODEL=agnes-2.0-flash
AGNES_FALLBACK_MODEL=
# Zero means pricing is not configured and is reported as UNPRICED, not free.
AGNES_FAST_INPUT_COST_PER_MILLION_USD=0
AGNES_FAST_OUTPUT_COST_PER_MILLION_USD=0
AGNES_PRIMARY_INPUT_COST_PER_MILLION_USD=0
AGNES_PRIMARY_OUTPUT_COST_PER_MILLION_USD=0
AGNES_FALLBACK_INPUT_COST_PER_MILLION_USD=0
AGNES_FALLBACK_OUTPUT_COST_PER_MILLION_USD=0

# Phase 20: keep disabled until multi-agent evaluation and rollout validation pass.
MULTI_AGENT_ENABLED=false
MULTI_AGENT_MAX_DELEGATIONS=3

# Optional semantic answer judge. Deterministic Reflection rules always run first.
REFLECTION_JUDGE_ENABLED=false
REFLECTION_JUDGE_TIMEOUT=45
REFLECTION_JUDGE_MIN_CONFIDENCE=0.85
REFLECTION_JUDGE_MAX_EVIDENCE_CHARS=8000
REFLECTION_JUDGE_INTENTS=POLICY_QA,PRODUCT_QA,ORDER_QA,RETURN_QA,RECOMMENDATION

RAG_RETRIEVAL_MODE=DOC_ONLY
STATE_BACKEND=memory
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=
STATE_KEY_PREFIX=aimall:state:v1
AIMALL_REDIS_BACKUP_OFFSITE_URI=
AIMALL_KNOWLEDGE_SOURCE_TIME_ZONE=Asia/Shanghai
SESSION_MEMORY_TTL_SECONDS=86400
PENDING_ACTION_TTL_SECONDS=600
PENDING_ACTION_EXECUTION_LEASE_SECONDS=180
PENDING_ACTION_RESULT_TTL_SECONDS=86400
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=aimall_knowledge_chunks_doubao

EMBEDDING_PROVIDER=ark
EMBEDDING_MODEL=ep-xxxxxxxxxxxxxxxx
EMBEDDING_MODEL_VERSION=doubao-embedding-vision-251215
EMBEDDING_DIM=2048
ARK_API_KEY=your-ark-key
ARK_EMBEDDING_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
