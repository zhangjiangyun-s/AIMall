COMPOSE_PROJECT_NAME=aimall-docker
DOCKER_HUB_MIRROR_PREFIX=

AIMALL_WEB_HOST_PORT=15173
AIMALL_ADMIN_HOST_PORT=15174
AIMALL_SERVER_HOST_PORT=18080
AIMALL_AI_HOST_PORT=18000
AIMALL_MYSQL_HOST_PORT=13306
AIMALL_REDIS_HOST_PORT=16379
AIMALL_MILVUS_HOST_PORT=19531
AIMALL_MINIO_HOST_PORT=19000
AIMALL_MINIO_CONSOLE_HOST_PORT=19001
AIMALL_MAILHOG_SMTP_HOST_PORT=11025
AIMALL_MAILHOG_WEB_HOST_PORT=18025
AIMALL_PROMETHEUS_HOST_PORT=19090
AIMALL_ALERTMANAGER_HOST_PORT=19093
AIMALL_GRAFANA_HOST_PORT=13000

MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
AIMALL_DB_APP_PASSWORD=replace-with-a-distinct-database-password
AIMALL_REDIS_PASSWORD=replace-with-a-distinct-redis-password
MINIO_ROOT_USER=aimall_minio
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-grafana-password

AIMALL_ENVIRONMENT=local
AIMALL_INTERNAL_API_SECRET=replace-with-a-long-random-legacy-secret
AIMALL_JAVA_TO_AI_KEY_ID=java-to-ai-docker-v1
AIMALL_JAVA_TO_AI_SECRET=replace-with-a-distinct-long-random-secret
AIMALL_AI_TO_JAVA_KEY_ID=ai-to-java-docker-v1
AIMALL_AI_TO_JAVA_SECRET=replace-with-another-distinct-long-random-secret
AIMALL_OBSERVABILITY_TOKEN=replace-with-a-distinct-long-random-token
AIMALL_EMAIL_CODE_PEPPER=replace-with-a-distinct-long-random-pepper

AIMALL_ADMIN_BOOTSTRAP_USERNAME=testadmin
AIMALL_ADMIN_BOOTSTRAP_PASSWORD=replace-with-at-least-12-characters
AIMALL_ADMIN_RESET_DEFAULT_PASSWORD=false

AIMALL_PAYMENT_PROVIDER=ALIPAY_SANDBOX
ALIPAY_ENABLED=true
ALIPAY_APP_ID=
ALIPAY_SELLER_ID=
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_BASE_URL=
ALIPAY_RETURN_URL=http://localhost:15173/orders
CLOUDFLARE_TUNNEL_TOKEN=

AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash
AGNES_FAST_MODEL=agnes-1.5-flash
AGNES_PRIMARY_MODEL=agnes-2.0-flash
AGNES_FALLBACK_MODEL=agnes-1.5-flash

ARK_API_KEY=
ARK_EMBEDDING_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
EMBEDDING_MODEL=replace-with-embedding-endpoint
EMBEDDING_MODEL_VERSION=doubao-embedding-vision-251215
EMBEDDING_DIM=2048
MILVUS_COLLECTION=aimall_knowledge_chunks_docker
